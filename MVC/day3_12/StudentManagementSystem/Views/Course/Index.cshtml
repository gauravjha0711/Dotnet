@model IEnumerable<StudentManagementSystem.Models.Course>

<h2>Courses</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Add Course</a>

<table class="table table-striped table-bordered">

    <thead class="table-dark">
        <tr>
            <th>Course Name</th>
            <th>Duration (Months)</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var course in Model)
        {
            <tr>

                <td>@course.CourseName</td>

                <td>@course.Duration</td>

                <td>
                    <span class="badge bg-primary">
                        @course.Department?.DepartmentName
                    </span>
                </td>

                <td>

                    <a asp-action="Details" asp-route-id="@course.CourseId" class="btn btn-info btn-sm">
                        Details
                    </a>

                    <a asp-action="Edit" asp-route-id="@course.CourseId" class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete" asp-route-id="@course.CourseId" class="btn btn-danger btn-sm">
                        Delete
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>