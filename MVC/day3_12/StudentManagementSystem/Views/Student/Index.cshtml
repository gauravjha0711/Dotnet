@model IEnumerable<StudentManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<h2 class="mb-4">Students List</h2>

<!-- ===================== ACTION BUTTONS ===================== -->

<div class="mb-4">

    <div class="btn-group mb-2">

        <a asp-action="OlderThan25" class="btn btn-outline-primary">
            Older Than 25
        </a>

        <a asp-action="RecentAdmissions" class="btn btn-outline-success">
            Recent Admissions
        </a>

        <a asp-action="OrderByName" class="btn btn-outline-dark">
            Order By Name
        </a>

        <a asp-action="Top5Recent" class="btn btn-outline-warning">
            Top 5 Recent
        </a>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Reset
        </a>

    </div>

</div>

<!-- ===================== SEARCH + FILTER ===================== -->

<form method="get" class="row mb-4">

    <div class="col-md-4">
        <input type="text"
               name="searchName"
               class="form-control"
               placeholder="Search Student Name..." />
    </div>

    <div class="col-md-3">
        <select name="departmentId"
                class="form-control"
                asp-items="@(new SelectList(ViewBag.Departments, "DepartmentId", "DepartmentName"))">

            <option value="">All Departments</option>

        </select>
    </div>

    <div class="col-md-3">
        <select name="courseId"
                class="form-control"
                asp-items="@(new SelectList(ViewBag.Courses, "CourseId", "CourseName"))">

            <option value="">All Courses</option>

        </select>
    </div>

    <div class="col-md-2">
        <button class="btn btn-primary w-100">
            Search
        </button>
    </div>

</form>

<a asp-action="Create" class="btn btn-success mb-3">
    Add Student
</a>

<!-- ===================== TABLE ===================== -->

<table class="table table-striped table-bordered">

    <thead class="table-dark">

        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Department</th>
            <th>Course</th>
            <th>Admission Date</th>
            <th>Actions</th>
        </tr>

    </thead>

    <tbody>

        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {

                <tr>

                    <td>@item.Name</td>

                    <td>@item.Age</td>

                    <td>
                        <span class="badge bg-primary">
                            @item.Department?.DepartmentName
                        </span>
                    </td>

                    <td>
                        <span class="badge bg-success">
                            @item.Course?.CourseName
                        </span>
                    </td>

                    <td>
                        @item.AdmissionDate.ToShortDateString()
                    </td>

                    <td>

                        <a asp-action="Details"
                               asp-route-id="@item.StudentId"
                               class="btn btn-info btn-sm">
                            Details
                        </a>

                        <a asp-action="Edit"
                               asp-route-id="@item.StudentId"
                               class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                               asp-route-id="@item.StudentId"
                               class="btn btn-danger btn-sm">
                            Delete
                        </a>

                    </td>

                </tr>

            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-danger">
                    No Students Found
                </td>
            </tr>
        }

    </tbody>

</table>