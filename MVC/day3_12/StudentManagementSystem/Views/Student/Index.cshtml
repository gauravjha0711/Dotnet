@model IEnumerable<StudentManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<h2 class="mb-3">Student List</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Add New Student</a>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        No students available.
    </div>
}

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.First().Name)</th>
            <th>Email</th>
            <th>Age</th>
            <th>Department</th>
            <th>Course</th>
            <th>Admission Date</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.Name</td>
                <td>@student.Email</td>
                <td>@student.Age</td>

                <td>
                    <span class="badge bg-primary">
                        @student.Department?.DepartmentName
                    </span>
                </td>

                <td>
                    <span class="badge bg-success">
                        @student.Course?.CourseName
                    </span>
                </td>

                <td>@student.AdmissionDate.ToShortDateString()</td>

                <td>
                    <a asp-action="Details" asp-route-id="@student.StudentId" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@student.StudentId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@student.StudentId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>