<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Student Management System</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <!-- ========================= -->
    <!-- Navigation Bar -->
    <!-- ========================= -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" asp-controller="TeacherDashboard" asp-action="Index">
                Student Management
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TeacherDashboard" asp-action="Index">
                            Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Department" asp-action="Index">
                            Departments
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Course" asp-action="Index">
                            Courses
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Student" asp-action="Index">
                            Students
                        </a>
                    </li>

                </ul>

                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">
                            Login
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Register">
                            Register
                        </a>
                    </li>

                </ul>

            </div>
        </div>
    </nav>

    <!-- ========================= -->
    <!-- Page Content -->
    <!-- ========================= -->

    <div class="container mt-4">

        @RenderBody()

    </div>

    <!-- ========================= -->
    <!-- Footer -->
    <!-- ========================= -->

    <footer class="bg-dark text-white text-center mt-5 p-3">
        <p>© 2026 Student Management System | ASP.NET Core MVC Project</p>
    </footer>

    <!-- Bootstrap JS -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>