@{
    ViewData["Title"] = "Home Page";
}

<div class="container text-center mt-5">

    <h1 class="display-4">Student Management System</h1>

    <p class="lead mt-3">
        Welcome to the Student Management System Web Application built using
        <strong>ASP.NET Core MVC</strong> and <strong>Entity Framework Core</strong>.
    </p>

    <hr />

    <div class="row mt-5">

        <div class="col-md-6">
            <div class="card shadow p-4">
                <h3>Teacher</h3>
                <p>Manage Departments, Courses and Students.</p>

                <a class="btn btn-primary"
                       asp-controller="Account"
                       asp-action="Login">
                    Teacher Login
                </a>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow p-4">
                <h3>Student</h3>
                <p>View your profile and course information.</p>

                <a class="btn btn-success"
                       asp-controller="Account"
                       asp-action="Register">
                    Student Register
                </a>
            </div>
        </div>

    </div>

</div>